# AIGentStyle / StyleTrainer preparation config

# Dataset and output roots. Keep real training data out of git unless intentionally curated.
AIGENT_STYLE_DATASET_ROOT=Plugin/AIGentStyle/datasets
AIGENT_STYLE_OUTPUT_ROOT=Plugin/AIGentStyle/outputs

# Stage 2 only generates dry-run plans. Real training must stay disabled.
AIGENT_STYLE_BACKEND=sd-scripts
AIGENT_STYLE_BASE_MODEL=flux-dev
AIGENT_STYLE_ALLOW_TRAINING=false
