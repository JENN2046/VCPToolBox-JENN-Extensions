# Required minimum settings
DWS_BIN=dws
DWS_MIN_VERSION=1.0.8
AUTH_MODE=auto
# Safe default: query-only. Switch to low_risk_write/full_write only after rollout approval.
DWS_GRAY_STAGE=query_only

# Optional custom_app credentials
DWS_CLIENT_ID=
DWS_CLIENT_SECRET=

# URL whitelist (comma separated). Empty means skip domain whitelist.
DWS_TRUSTED_DOMAINS=

# Audit and runtime tuning
AUDIT_LOG_PATH=
DWS_TIMEOUT_MS=60000
DWS_SCHEMA_CACHE_TTL_MS=300000
DWS_MAX_ARG_BYTES=262144
DWS_BATCH_LIMIT=500
DWS_DEBUG=false
DWS_TOOL_MAP_PATH=
